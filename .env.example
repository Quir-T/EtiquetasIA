APP_NAME=Anamnesis API
LOG_LEVEL=INFO
API_KEY=change-me
CORS_ORIGINS=http://localhost,http://127.0.0.1
MAX_TEXT_LENGTH=12000
NLP_PROVIDER_TIMEOUT_SECONDS=10
DATABASE_DSN=postgresql+psycopg://app:app@postgres:5432/anamnesis_db
DB_SSL_MODE=disable
DB_SSL_CA=
DB_SSL_CERT=
DB_SSL_KEY=
PROMPT_VERSION=v1
NLP_PROVIDER=google
ANONYMIZER_MODULE=src.infrastructure.anonymizer.anonymizer
ANONYMIZER_CLASS=LegacySpacyAnonymizer
GOOGLE_NLP_ENDPOINT=https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent
GOOGLE_NLP_MODEL=gemini-1.5-flash
GOOGLE_API_KEY=
GOOGLE_NLP_MAX_RETRIES=0
QWEN_NLP_ENDPOINT=http://ollama:11434/api/generate
QWEN_NLP_MODEL=qwen2.5:7b-instruct
QWEN_API_KEY=
